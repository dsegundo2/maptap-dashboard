{
  "name": "maptap-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22.12" },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "data:refresh": "node scripts/fetch-data.mjs",
    "og:generate": "node scripts/generate-og.mjs",
    "build": "npm run og:generate && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint .",
    "test": "vitest run",
    "test:ui": "playwright test --project=chromium"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@playwright/test": "^1.53.1",
    "eslint": "^9.30.0",
    "globals": "^16.2.0",
    "sharp": "^0.34.2",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
